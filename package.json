{
  "name": "ngx-transition-content",
  "description": "Switch between content: fade out, transition dimensions, fade in",
  "version": "2.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": "^22.13.0 || >=24.0.0",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "ng": "ng",
    "start": "pnpm run build:lib && ng serve ngx-transition-content-demo",
    "build": "pnpm run build:lib && pnpm run build:demo",
    "build:lib": "ng build ngx-transition-content",
    "build:demo": "ng build ngx-transition-content-demo",
    "watch": "ng build ngx-transition-content --watch --configuration development",
    "test": "pnpm run test:lib && pnpm run test:demo",
    "test:lib": "ng test ngx-transition-content --watch=false",
    "test:demo": "pnpm run build:lib && ng test ngx-transition-content-demo --watch=false",
    "pack:lib": "pnpm run build:lib && cp README.md LICENSE ./dist/ngx-transition-content/",
    "pack:dry-run": "pnpm run pack:lib && pnpm --dir ./dist/ngx-transition-content pack --dry-run"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": false,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ciriousjoker/ngx-transition-content.git"
  },
  "keywords": [
    "angular",
    "animation",
    "transition",
    "fade",
    "height",
    "template",
    "ng-content"
  ],
  "author": "Philipp Bauer",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ciriousjoker/ngx-transition-content/issues"
  },
  "homepage": "https://github.com/ciriousjoker/ngx-transition-content#readme",
  "dependencies": {
    "@angular/common": "20.2.4",
    "@angular/compiler": "20.2.4",
    "@angular/core": "20.2.4",
    "@angular/platform-browser": "20.2.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "20.2.2",
    "@angular/cli": "20.2.2",
    "@angular/compiler-cli": "20.2.4",
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@types/node": "^22.20.0",
    "@vitest/coverage-v8": "3.2.7",
    "jsdom": "^26.1.0",
    "ng-packagr": "20.2.0",
    "prettier": "^3.9.4",
    "typescript": "~5.9.3",
    "vitest": "3.2.7"
  }
}
