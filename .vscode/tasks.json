{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve Website",
      "detail": "Builds the library once and serves the demo app.",
      "type": "shell",
      "command": "pnpm",
      "args": ["start"],
      "isBackground": true,
      "presentation": {
        "focus": true,
        "panel": "dedicated"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": {
        "owner": "typescript",
        "source": "ts",
        "applyTo": "closedDocuments",
        "fileLocation": ["relative", "${cwd}"],
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "Application bundle generation complete|Failed to compile."
          }
        }
      }
    },
    {
      "label": "Test",
      "detail": "Runs the Vitest-backed Angular test suite.",
      "type": "shell",
      "command": "pnpm",
      "args": ["test"],
      "presentation": {
        "focus": true,
        "panel": "dedicated"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Reformat all files",
      "type": "shell",
      "command": "pnpm exec prettier --write --ignore-unknown ."
    }
  ]
}
